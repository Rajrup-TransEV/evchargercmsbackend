// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//application user and super user user model
model User {
  id              Int              @id @default(autoincrement())
  uid             String           @unique
  username        String           @unique
  email           String           @unique
  password        String?
  userType        String?
  otp             String?
  otpExpiration   DateTime?
  emailVerified   Boolean?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  appuserprofile   AppUserProfile[]
 wallets    wallet[]
}

model AppUserProfile {
  id              Int              @id @default(autoincrement())
  uid             String           @unique // This will be the foreign key
  firstname       String?
  lastname        String?
  bio             String?
  address         String?
  phonenumber     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  userId String?
  user User?   @relation(fields: [userId],references: [uid])
 
}




//super admin created admin details
model UserProfile {
  id                Int              @id @default(autoincrement())
  uid               String?          @unique
  firstname         String?
  lastname          String?
  email             String?     @unique
  password          String?
  address           String?
  phonenumber       String?      @unique
  role              String?
  designation       String?
  otp    String?
  otpExpiration DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  financialDetails  Financial_details? @relation("UserFinancialDetails") // Define relation name
  chargerUnits      Charger_Unit[]     // Define the relationship with Charger_Unit
  wallets    wallet[]
  vehicleowener Assigntovehicleowener[]
  hubs  Addhub[]
}

//fiancial details for all of users 
model Financial_details {
  id                Int              @id @default(autoincrement())
  uid               String?          @unique
  bank_account_number String?
  isfc_code        String?
  bank_name        String?
  branch_name      String?
  branch_address    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  userProfileId    String?             @unique // Ensure this is unique for a one-to-one relationship
  userProfile      UserProfile?     @relation("UserFinancialDetails", fields: [userProfileId], references: [uid]) // Define relation name and fields
  
}

//chargerunit buying model
model Charger_Unit {
  id                          Int              @id @default(autoincrement())
  uid                         String?          @unique
  chargeridentity             String?  @db.VarChar(655)
  Chargerserialnum             String?
  ChargerName                 String?
  Chargerhost                 String?
  Segment                     String?
  Subsegment                  String?
  Total_Capacity              String?
  Chargertype                 String?
  parking                     String?
  number_of_connectors        String?
  Connector_type              String?
  connector_total_capacity    String?
  lattitude                   String?
  longitute                   String?
  full_address                String?
  charger_use_type            String? // if the charger will be used for private or commercial
  twenty_four_seven_open_status String?
  charger_image               String?
  userId                      String?             // Foreign key to UserProfile
  chargerbuyer                        UserProfile?     @relation(fields: [userId], references: [uid])
  
  createdAt        DateTime         @default(now())
  // updatedAt        DateTime         @updatedAt


  QRCode QRCode[]
}
//all of the role will goes here
model AssignRoles{
  id                          Int              @id @default(autoincrement())
  uid                         String?          @unique
  userid     String?
  rolename String?  
  roledesc  String?
   createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

//vehicle registration model
model Assigntovechicles {
  id              Int              @id @default(autoincrement())
  uid             String?          @unique
  vehiclename     String?
  vehiclemodel    String?
  vehiclelicense   String? @unique
  vehicleowner     String?
  vehiclecategory   String?
  vehicletype      String?
  vehicleowenerId        String?  // Ensure one vehicle per driver
  vehicleowener          Assigntovehicleowener?  @relation(fields: [vehicleowenerId], references: [uid])
  isvehicleassigned Boolean?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

//vehicle owener model
model Assigntovehicleowener {
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  vehicleowenerfirstname     String?
  vehicleowenerlastename     String?
 vehicleoweneremail         String?  @unique
 phonenumber                  String?
  vehicleowenerlicense       String?  @unique
 vehicleowenergovdocs       String?
  vehicleowenernationality   String?
 adminid             String? @unique
 adminuserprofile UserProfile? @relation(fields: [adminid],references: [uid])
 vehicleoweneraddress       String?
 vehicleowenerrole          String?

  vehicles            Assigntovechicles[] // One driver can have multiple vehicles
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

//to be implemented in future
model RazorpayData {
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  orderId             String?               @unique
  paymentId           String?               @unique
  amount              String?
  currency            String?
  status              String?
  attempts            String?
  method              String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}
//group of models for analytics and retention
model Analytics{
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  totalnumberofusers  String?
  totalnumberofuserprofiles String?
  perdaynewusercount   String?
  countofroles  String?
  countofchargerunits String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}
//daily signup log retention model
model DailySignup {
  id             Int      @id @default(autoincrement())
  uid String?
  date           DateTime @default(now())
  newSignupCount Int      @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model LogRetention{
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  messagetype        String?
  messages   Json?
  filelocation   String?

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}


//model for generating qr code

model QRCode {
  id          Int          @id @default(autoincrement())
  uid         String?      @unique
  chargerid   String?      // This will reference Charger_Unit.uid
  qrcodedata  String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Establishing the relationship
  charger     Charger_Unit? @relation(fields: [chargerid], references: [uid])
}

//model for generating wallet
model wallet{
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  userprofilerelatedwallet String?
  userprofile   UserProfile? @relation(fields: [userprofilerelatedwallet],references: [uid])
  appuserrelatedwallet String?
  user User? @relation(fields: [appuserrelatedwallet],references: [uid])
  balance String?
  iswalletrechargedone Boolean?
  recharger_made_by_which_user   String?

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model walletreachargehistory{
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  userassociatedid            String?
  previousbalance String?
  balanceleft String?
  addedbalance String?
  numberofrecharge String?
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model reateofpayment{
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  setpaymentrate String?
  tax  String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Counter {
  id    Int    @id @default(autoincrement())
  value Int    @default(100)
}

model Addhub{
    id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  hubname String?
  hubchargers Json?    
  hubtariff  String?
  hublocation String?
  adminuid String?
 adminuserprofile UserProfile? @relation(fields: [adminuid],references: [uid])
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

}

model Transactionsdetails{
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  paymentid  String?
  walletid String?
  userid String?
  price String?
  chargeruid String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model iptracker{
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  ipaddress String?
  filepath String?
  datetimeofaccess String?
  messages String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}
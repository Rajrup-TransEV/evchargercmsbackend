// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model User {
  id        Int      @id @default(autoincrement())
  uid       String   @unique
  username  String   @unique
  email     String   @unique
  password  String?
  userType  String?
  otp    String?
  otpExpiration DateTime?
  emailVerified Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
}
model UserProfile {
  id                Int              @id @default(autoincrement())
  uid               String?          @unique
  firstname         String?
  lastname          String?
  email             String?
  password          String?
  address           String?
  phonenumber       String?
  role              String?
  designation       String?
  otp    String?
  otpExpiration DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  financialDetails  Financial_details? @relation("UserFinancialDetails") // Define relation name
  chargerUnits      Charger_Unit[]     // Define the relationship with Charger_Unit
}
model Financial_details {
  id                Int              @id @default(autoincrement())
  uid               String?          @unique
  bank_account_number String?
  isfc_code        String?
  bank_name        String?
  branch_name      String?
  branch_address    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  userProfileId    String?             @unique // Ensure this is unique for a one-to-one relationship
  userProfile      UserProfile?     @relation("UserFinancialDetails", fields: [userProfileId], references: [uid]) // Define relation name and fields
  
}

model Charger_Unit {
  id                          Int              @id @default(autoincrement())
  uid                         String?          @unique
  ChargerName                 String?
  Chargerhost                 String?
  Segment                     String?
  Subsegment                  String?
  Total_Capacity              String?
  Chargertype                 String?
  parking                     String?
  number_of_connectors        String?
  Connector_type              String?
  connector_total_capacity    String?
  lattitude                   String?
  longitute                   String?
  full_address                String?
  charger_use_type            String? // if the charger will be used for private or commercial
  twenty_four_seven_open_status String?
  charger_image               String?
  
  userId                      String?             // Foreign key to UserProfile
  chargerbuyer                        UserProfile?     @relation(fields: [userId], references: [uid])
  
  createdAt        DateTime         @default(now())
  // updatedAt        DateTime         @updatedAt
}

model AssignRoles{
  id                          Int              @id @default(autoincrement())
  uid                         String?          @unique
  userid     String?
  rolename String?  
  roledesc  String?
   createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}


model Assigntovechicles {
  id              Int              @id @default(autoincrement())
  uid             String?          @unique
  vehiclename     String?
  vehiclemodel    String?
  vehiclelicense   String?
  vehicleowner     String?
  vehicletype      String?
  driverId        String?          @unique // Ensure one vehicle per driver
  driver          AssigntoDriver?  @relation(fields: [driverId], references: [uid])
  isvehicleassigned Boolean?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model AssigntoDriver {
  id                  Int                  @id @default(autoincrement())
  uid                 String?              @unique
  driverfirstname     String?
  driverlastename     String?
  driveremail         String?
  driverlicense       String?
  drivergovdocs       String?
  drivernationality   String?
  diverid             String?
  driveraddress       String?
  driverrole          String?

  vehicles            Assigntovechicles[] // One driver can have multiple vehicles
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

